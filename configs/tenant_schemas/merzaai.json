      {
        "key": "industry",
        "type": "select",
        "label": "Industry",
        "options": [
          { "value": "IT", "label": "IT" },
          { "value": "Finance", "label": "Finance" },
          { "value": "Healthcare", "label": "Healthcare" },
          { "value": "Education", "label": "Education" },
          { "value": "Manufacturing", "label": "Manufacturing" },
          { "value": "Retail", "label": "Retail" },
          { "value": "Real Estate", "label": "Real Estate" },
          { "value": "Other", "label": "Other" }
        ]
      },
      {
        "key": "source",
        "type": "select",
        "label": "Source",
        "required": true,
        "options": [
          { "value": "Website", "label": "Website" },
          { "value": "Referral", "label": "Referral" },
          { "value": "Social Media", "label": "Social Media" },
          { "value": "Cold Call", "label": "Cold Call" },
          { "value": "Event", "label": "Event" },
          { "value": "Email Campaign", "label": "Email Campaign" },
          { "value": "Other", "label": "Other" }
        ]
      },
      {
        "key": "probability",
        "type": "number",
        "label": "Probability (%)",
        "min": 0,
        "max": 100
      },
      {
        "key": "value",
        "type": "currency",
        "label": "Deal Value"
      },
      {
        "key": "budget",
        "type": "currency",
        "label": "Budget"
      },
      {
        "key": "expected_close_date",
        "type": "date",
        "label": "Expected Close Date"
      },
      {
        "key": "decision_maker",
        "type": "text",
        "label": "Decision Maker"
      },
      {
        "key": "website",
        "type": "url",
        "label": "Website"
      },
      {
        "key": "location",
        "type": "text",
        "label": "Location"
      },
      {
        "key": "employees",
        "type": "number",
        "label": "Number of Employees"
      },
      
      {
        "key": "notes",
        "label": "Notes",
        "type": "repeat",
        "item_label": "Note",
        "fields": [
          {
            "key": "text",
            "type": "textarea",
            "label": "Note"
          },
          {
            "key": "created_by",
            "type": "user",
            "label": "Written By"
          }
        ]
      }
    ],

    "default_sort": {
      "field": "created_at",
      "direction": "desc"
    },

    "page_size": 10
  },

